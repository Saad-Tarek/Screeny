# Never commit secrets or captured screenshots
.env
SessionArchive/
*.png
*.log
__pycache__/
.DS_Store
.impeccable/
.claude/*
!.claude/settings.local.json

# Rust
/target/

# Node / SvelteKit
node_modules/
/build/
/.svelte-kit/
vite.config.js.timestamp-*

# Tauri
/src-tauri/target/
/src-tauri/gen/

# Bundled app icons are committed on purpose
!src-tauri/icons/*.png
!static/*.png
