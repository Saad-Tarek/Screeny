# Copy this file to ".env" and fill in your values. The real .env is gitignored.
# The script auto-loads .env on startup.

ARCHIVER_GMAIL=you@gmail.com

# 16-char Gmail App Password (no spaces). Create one at:
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification)
ARCHIVER_APP_PASSWORD=your_app_password_here

# Optional: send to a different address (defaults to ARCHIVER_GMAIL).
ARCHIVER_RECIPIENT=you@gmail.com

# How many screenshots to capture per minute (2 = one every 30s).
ARCHIVER_SHOTS_PER_MINUTE=2

# How many shots to bundle into a single email (1 = send each one immediately).
ARCHIVER_BATCH_SIZE=1
